# ─────────────────────────────────────────────────────────────────────────────
# AVA HMS Frontend — environment template.
# Copy this file to `.env` and adjust for your machine:  cp .env.example .env
#
# NEXT_PUBLIC_* variables are inlined into the client bundle at BUILD time.
# They are NOT secret — never put tokens or passwords here.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the AVA HMS backend API (no trailing slash).
# Local dev typically points at your locally-running Laravel API.
# In CI this is provided by the GitHub Actions Variable of the same name.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
